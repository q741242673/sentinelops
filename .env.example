SENTINELOPS_ENVIRONMENT=development
SENTINELOPS_TOOL_BACKEND=simulator
SENTINELOPS_MODEL_PROVIDER=rule_based
SENTINELOPS_MODEL_NAME=demo

# Durable incident state. PostgreSQL is required when ENVIRONMENT=production.
# SENTINELOPS_DATABASE_URL=postgresql+asyncpg://sentinelops:replace-me@localhost/sentinelops
# Kubernetes deployments can mount the same value as a read-only file instead.
# Do not configure both DATABASE_URL and DATABASE_URL_FILE.
# SENTINELOPS_DATABASE_URL_FILE=/var/run/secrets/sentinelops/database-url
# Production uses a separate, long-lived audit key; never reuse the Webhook token.
# SENTINELOPS_AUDIT_HMAC_KEY_FILE=/var/run/secrets/sentinelops/audit-hmac-key
SENTINELOPS_AUDIT_KEY_ID=development-unkeyed
# External anchoring uses a third, independent credential and a stable deployment ID.
# SENTINELOPS_AUDIT_ANCHOR_URL=https://audit.example.com/v1/anchors
# SENTINELOPS_AUDIT_ANCHOR_INVENTORY_URL=https://audit.example.com/v1/anchor-inventory
# SENTINELOPS_AUDIT_ANCHOR_SOURCE_ID=prod-cluster-a
# SENTINELOPS_AUDIT_ANCHOR_BEARER_TOKEN_FILE=/var/run/secrets/sentinelops/audit-anchor-token
# SENTINELOPS_AUDIT_ANCHOR_RECONCILE_BEARER_TOKEN_FILE=/var/run/secrets/sentinelops/audit-anchor-reconcile-token
# SENTINELOPS_AUDIT_ANCHOR_TRUSTED_RECEIVER_ID=company-audit-ledger
# SENTINELOPS_AUDIT_ANCHOR_RECEIPT_PUBLIC_KEYS_FILE=/etc/sentinelops-anchor/receipt-public-keys.json
# SENTINELOPS_AUDIT_ANCHOR_RECONCILE_INTERVAL_SECONDS=60
# SENTINELOPS_AUDIT_ANCHOR_RECONCILE_MAX_STALENESS_SECONDS=300
# SENTINELOPS_AUDIT_ANCHOR_ENFORCEMENT_REQUIRED=true
# 生产 API 的人工操作必须使用企业 OIDC；本地演示保持 disabled。
# SENTINELOPS_OPERATOR_AUTH_MODE=oidc
# SENTINELOPS_OIDC_ISSUER=https://identity.example.com
# SENTINELOPS_OIDC_AUDIENCE=sentinelops-api
# SENTINELOPS_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
# SENTINELOPS_OIDC_ROLES_CLAIM=roles
# SENTINELOPS_OIDC_HUMAN_CLAIM=sentinelops_actor_type
# SENTINELOPS_OIDC_HUMAN_VALUE=human

# Local reference receiver. Use a different database from the SentinelOps API.
# SENTINELOPS_ANCHOR_SERVICE_DATABASE_URL=sqlite+aiosqlite:///./anchor-ledger.db
# SENTINELOPS_ANCHOR_SERVICE_BEARER_TOKEN=replace-with-32-random-bytes
# SENTINELOPS_ANCHOR_SERVICE_INVENTORY_BEARER_TOKEN=replace-with-another-32-random-bytes
# SENTINELOPS_ANCHOR_SERVICE_ALLOWED_SOURCE_ID=local-kind
# SENTINELOPS_ANCHOR_SERVICE_RECEIVER_ID=local-reference-anchor
# SENTINELOPS_ANCHOR_SERVICE_SIGNING_PRIVATE_KEY_FILE=./anchor-receipt-private.pem
# SENTINELOPS_ANCHOR_SERVICE_SIGNING_KEY_ID=local-anchor-receipt-v1
# Set true only for disposable development databases. Production rejects it.
# Run `sentinelops db-init` as a separate migration job, then `sentinelops db-check`.
SENTINELOPS_DATABASE_AUTO_CREATE=false
# Stable ID for one cluster / Alertmanager source. Required to avoid cross-cluster collisions.
SENTINELOPS_ALERTMANAGER_SOURCE_ID=local-kind
# Local development may stay disabled. Production requires bearer or hmac_sha256.
SENTINELOPS_ALERTMANAGER_WEBHOOK_AUTH_MODE=disabled
# Native Alertmanager can send this token with its http_config.authorization setting.
# SENTINELOPS_ALERTMANAGER_WEBHOOK_BEARER_TOKEN=replace-with-32-or-more-random-bytes
# SENTINELOPS_ALERTMANAGER_WEBHOOK_BEARER_TOKEN_FILE=/var/run/secrets/sentinelops/webhook-bearer-token
# hmac_sha256 is for a signing gateway or relay; native Alertmanager does not sign bodies.
# SENTINELOPS_ALERTMANAGER_WEBHOOK_SIGNING_SECRET=replace-with-32-or-more-random-bytes
# SENTINELOPS_ALERTMANAGER_WEBHOOK_SIGNING_SECRET_FILE=/var/run/secrets/sentinelops/webhook-signing-secret
# During rotation, configure the matching previous secret and an absolute UTC expiry.
# SENTINELOPS_ALERTMANAGER_WEBHOOK_PREVIOUS_BEARER_TOKEN=replace-me-temporarily
# SENTINELOPS_ALERTMANAGER_WEBHOOK_PREVIOUS_SIGNING_SECRET=replace-me-temporarily
# SENTINELOPS_ALERTMANAGER_WEBHOOK_PREVIOUS_SECRET_EXPIRES_AT=2026-07-24T00:00:00Z
SENTINELOPS_ALERTMANAGER_WEBHOOK_SIGNATURE_TTL_SECONDS=300
SENTINELOPS_ALERTMANAGER_WEBHOOK_SIGNATURE_FUTURE_SKEW_SECONDS=30
SENTINELOPS_ALERTMANAGER_WEBHOOK_MAX_BODY_BYTES=1048576
SENTINELOPS_WORKER_LEASE_TTL_SECONDS=60
SENTINELOPS_WORKER_LEASE_HEARTBEAT_SECONDS=15
SENTINELOPS_WORKER_RECONCILIATION_INTERVAL_SECONDS=5
# Use embedded only for local development. Production API requires external.
SENTINELOPS_EXECUTOR_MODE=embedded
SENTINELOPS_EXECUTOR_CLAIM_TTL_SECONDS=60
SENTINELOPS_EXECUTOR_POLL_INTERVAL_SECONDS=0.5
SENTINELOPS_EXECUTOR_RESULT_TIMEOUT_SECONDS=120

# OpenAI-compatible providers (OpenAI, DeepSeek, vLLM, Ollama gateways, etc.)
# SENTINELOPS_MODEL_PROVIDER=openai_compatible
# SENTINELOPS_MODEL_NAME=your-model-name
# SENTINELOPS_MODEL_BASE_URL=https://api.example.com/v1
# SENTINELOPS_MODEL_API_KEY=replace-me
# SENTINELOPS_MODEL_API_KEY_FILE=/var/run/secrets/sentinelops/model-api-key
# SENTINELOPS_MODEL_TIMEOUT_SECONDS=60

# Live console endpoints (configured automatically by `make console-live`)
# SENTINELOPS_DEMO_ORDER_URL=http://127.0.0.1:28080
# SENTINELOPS_DEMO_INVENTORY_URL=http://127.0.0.1:28081
# SENTINELOPS_PROMETHEUS_URL=http://127.0.0.1:29090
# SENTINELOPS_LOKI_URL=http://127.0.0.1:23100
# SENTINELOPS_TEMPO_URL=http://127.0.0.1:23200

SENTINELOPS_KUBERNETES_NAMESPACE=sentinelops-demo
SENTINELOPS_DEMO_ENABLED=false
SENTINELOPS_DEMO_NAMESPACE=sentinelops-demo
SENTINELOPS_AUTO_APPROVE_MAX_RISK=low

# Optional read-only observability backends
# SENTINELOPS_PROMETHEUS_URL=http://127.0.0.1:9090
# SENTINELOPS_LOKI_URL=http://127.0.0.1:3100
# SENTINELOPS_TEMPO_URL=http://127.0.0.1:3200
# SENTINELOPS_VERIFICATION_PROBE_URL=http://order-service.example
SENTINELOPS_OBSERVABILITY_TIMEOUT_SECONDS=10

# Bounded diagnosis reflection and optional read-only rollout/Git correlation
SENTINELOPS_DIAGNOSIS_CONFIDENCE_THRESHOLD=0.8
SENTINELOPS_MAX_REFLECTION_ROUNDS=1
# SENTINELOPS_CHANGE_REPOSITORY_PATH=/absolute/path/to/sentinelops
SENTINELOPS_CHANGE_HISTORY_HOURS=24
SENTINELOPS_CHANGE_HISTORY_LIMIT=20
