SENTINELOPS_ENVIRONMENT=development
SENTINELOPS_TOOL_BACKEND=simulator
SENTINELOPS_MODEL_PROVIDER=rule_based
SENTINELOPS_MODEL_NAME=demo

# OpenAI-compatible providers (OpenAI, DeepSeek, vLLM, Ollama gateways, etc.)
# SENTINELOPS_MODEL_PROVIDER=openai_compatible
# SENTINELOPS_MODEL_NAME=your-model-name
# SENTINELOPS_MODEL_BASE_URL=https://api.example.com/v1
# SENTINELOPS_MODEL_API_KEY=replace-me

# Live console endpoints (configured automatically by `make console-live`)
# SENTINELOPS_DEMO_ORDER_URL=http://127.0.0.1:28080
# SENTINELOPS_DEMO_INVENTORY_URL=http://127.0.0.1:28081
# SENTINELOPS_PROMETHEUS_URL=http://127.0.0.1:29090
# SENTINELOPS_LOKI_URL=http://127.0.0.1:23100
# SENTINELOPS_TEMPO_URL=http://127.0.0.1:23200

SENTINELOPS_KUBERNETES_NAMESPACE=sentinelops-demo
SENTINELOPS_AUTO_APPROVE_MAX_RISK=low

# Optional read-only observability backends
# SENTINELOPS_PROMETHEUS_URL=http://127.0.0.1:9090
# SENTINELOPS_LOKI_URL=http://127.0.0.1:3100
# SENTINELOPS_TEMPO_URL=http://127.0.0.1:3200
SENTINELOPS_OBSERVABILITY_TIMEOUT_SECONDS=10
